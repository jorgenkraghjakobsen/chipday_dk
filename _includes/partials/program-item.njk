<div class="program-item{% if item.type == 'keynote' %} program-keynote{% endif %}">
    <div class="program-time">{{ item.time }}</div>
    <div class="program-content">
        <h3>{{ item.title }}</h3>
        {% if item.type == "keynote" %}
        <p class="speaker">{{ item.speaker }}{% if item.affiliation %} &mdash; {{ item.affiliation }}{% endif %}</p>
        {% endif %}
        {% if item.description %}
        <p class="speaker">{{ item.description }}</p>
        {% endif %}
        {% if item.talks %}
        <ul class="talks">
            {% for talk in item.talks %}
            <li>{% if talk.lightning %}<span class="lightning-badge">Lightning talk</span> {% endif %}<strong>{{ talk.title }}</strong> &mdash; {{ talk.speaker }}{% if talk.affiliation %} ({{ talk.affiliation }}){% endif %}</li>
            {% endfor %}
        </ul>
        {% endif %}
    </div>
</div>
