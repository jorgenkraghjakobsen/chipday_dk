<style>
  .template-columns {
    display: flex;
    gap: 2rem;
    align-items: center;
    margin-bottom: 2rem;
  }
  .template-left {
    flex: 1;
  }
  .template-right {
    flex-shrink: 0;
  }
  @media (max-width: 600px) {
    .template-columns {
      flex-direction: column;
    }
  }
  .upload-slot {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem 1.5rem;
    margin-bottom: 0.75rem;
    transition: border-color 0.2s;
  }
  .upload-slot:hover {
    border-color: var(--accent-dim);
  }
  .slot-status {
    margin: 0.5rem 0;
    font-size: 0.85rem;
  }
  .status-none {
    color: var(--text-dim);
  }
  .status-uploaded {
    color: var(--green);
    font-weight: 600;
  }
  .upload-form {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .file-label {
    position: relative;
    cursor: pointer;
  }
  .file-label input[type="file"] {
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0;
  }
  .file-btn {
    display: inline-block;
    background: var(--bg-card-hover);
    border: 1px solid var(--border);
    color: var(--text-dim);
    padding: 0.4rem 1rem;
    border-radius: 0.4rem;
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .file-btn:hover {
    border-color: var(--accent-dim);
    color: var(--text);
  }
  .file-label.has-file .file-btn {
    border-color: var(--accent);
    color: var(--text);
  }
  .upload-btn {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 0.4rem 1.2rem;
    border-radius: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }
  .upload-btn:hover {
    background: #3d7ae8;
  }
  .quiz-check {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    cursor: pointer;
  }
  .quiz-check input[type="checkbox"] {
    width: 1rem;
    height: 1rem;
    accent-color: var(--accent);
    cursor: pointer;
  }
  .quiz-check input[type="checkbox"]:checked + span {
    color: var(--green, #4caf50);
  }
</style>

<script>
  // Show selected filename
  document.querySelectorAll('.file-label input[type="file"]').forEach(input => {
    input.addEventListener('change', () => {
      const label = input.closest('.file-label');
      const btn = label.querySelector('.file-btn');
      if (input.files.length) {
        btn.textContent = input.files[0].name;
        label.classList.add('has-file');
      } else {
        btn.textContent = 'Choose file';
        label.classList.remove('has-file');
      }
    });
  });

  // Fetch upload status on load
  fetch('/2026/upload/status')
    .then(r => r.json())
    .then(data => {
      // Slot upload status
      if (data.slots) {
        for (const [slotId, info] of Object.entries(data.slots)) {
          const el = document.getElementById('status-' + slotId);
          if (!el) continue;
          if (info.uploaded) {
            el.innerHTML = '<span class="status-uploaded">Uploaded: <a href="/2026/uploads/' + slotId + '/' + encodeURIComponent(info.filename) + '" style="color: var(--green); text-decoration: underline;" download>' + info.filename + '</a></span>';
          }
        }
      }
      // Merged deck status
      if (data.merged) {
        for (const [sessionId, info] of Object.entries(data.merged)) {
          const el = document.getElementById('merged-' + sessionId);
          if (!el) continue;
          const status = el.querySelector('.merged-status');
          if (info.available) {
            status.innerHTML = '<a href="/2026/merged/' + sessionId + '.pptx" style="color: var(--green); font-weight: 600;">Download merged deck</a>';
          }
        }
      }
    })
    .catch(() => {});

  // Quiz checkbox persistence (server-side)
  function saveQuizCheck(id, checked) {
    fetch('/2026/upload/quiz-status/' + id, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({checked: checked})
    }).catch(() => {});
  }
  fetch('/2026/upload/quiz-status')
    .then(r => r.json())
    .then(data => {
      for (const [id, checked] of Object.entries(data)) {
        const el = document.getElementById(id);
        if (el) el.checked = checked;
      }
    })
    .catch(() => {});

  // Rebuild presentations folder
  function rebuildPresentations() {
    const btn = document.getElementById('rebuild-btn');
    const status = document.getElementById('rebuild-status');
    btn.disabled = true;
    btn.textContent = 'Rebuilding...';
    status.textContent = '';
    fetch('/2026/upload/rebuild-presentations', { method: 'POST' })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          status.style.color = 'var(--green, #4caf50)';
          status.textContent = 'Done — ' + data.files + ' files rebuilt';
        } else {
          status.style.color = '#e74c3c';
          status.textContent = 'Error: ' + (data.error || 'unknown');
        }
      })
      .catch(err => {
        status.style.color = '#e74c3c';
        status.textContent = 'Failed: ' + err.message;
      })
      .finally(() => {
        btn.disabled = false;
        btn.textContent = 'Rebuild';
      });
  }
</script>
