<div class="page-header" style="position: relative; overflow: hidden;">
  <img src="/assets/hero-wafer.jpg" alt="" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0;">
  <div style="position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, rgba(15,17,23,0.6) 0%, rgba(15,17,23,0.8) 50%, var(--bg) 100%);"></div>
  <h1 style="position: relative; z-index: 2;">Speaker <span>Resources</span></h1>
  <p style="position: relative; z-index: 2;">Practical information and upload area for Chip Day 2026 presenters</p>
</div>

<section style="max-width: 800px; margin: 0 auto;">
  <h2>Presentation Template</h2>
  <p style="color: var(--text-dim); margin-bottom: 1rem;">
    To create a unified look across the event, we ask all speakers to use our common presentation template.
    This helps communicate a shared community identity for Danish chip design.
    Individual presentations will be merged into one combined deck per session,
    so the final result is three seamless slide decks — one for each session.
  </p>
  <div class="template-columns">
    <div class="template-left">
      <a href="/2026/ChipDay2026Template.pptx" style="display: inline-block; background: var(--accent); color: #fff; padding: 0.6rem 1.5rem; border-radius: 0.5rem; font-weight: 600;">Download Template (.pptx)</a>
    </div>
    <div class="template-right">
      <h3 style="margin-bottom: 0.5rem; font-size: 0.95rem;">Example from 2025</h3>
      <img src="/2026/example-2025.png" alt="Example slide from Chip Day 2025" style="max-width: 280px; width: 100%; border-radius: 0.5rem; border: 1px solid var(--border);">
      <p style="color: var(--text-dim); font-size: 0.75rem; margin-top: 0.4rem;">J. K. Jakobsen (IC Works) &amp; J. S. Andersen (SyoSil)</p>
    </div>
  </div>

  <hr class="divider" style="margin-bottom: 2.5rem;">

  <div id="uploads">

  <h2>Quiz, Kahoot &amp; Prizes</h2>
  <p style="color: var(--text-dim); margin-bottom: 1.5rem;">
    Each presenter is asked to prepare <strong>3 quiz questions</strong> with <strong>4 answer options</strong> each (mark the correct one).
    The questions will be used in a live Kahoot quiz during the networking breaks, with prizes for the top scorers!
    Send your questions to <a href="mailto:martine.chegaray@synopsys.com" style="color: var(--accent);">martine.chegaray@synopsys.com</a> and tick the checkbox when done.
  </p>

  <h2>Session 1: Chip Education in Denmark</h2>
  <p style="color: var(--text-dim); margin-bottom: 1rem;">13:00 &ndash; 14:00</p>
  <div style="margin-bottom: 2.5rem;">
    {% for slot in [
      {id: "s1-intro",     title: "Welcome & Introduction",                    who: "Organizers",                       quiz: false},
      {id: "s1-dam",       title: "Keynote: The Importance of IC Development",  who: "Brian Dam Pedersen, GN",          quiz: true},
      {id: "s1-lynggaard", title: "Analogue Courses",                           who: "Per Lynggaard, DTU Electro",      quiz: true},
      {id: "s1-schoeberl", title: "First Student Tape-Out",                     who: "Martin Schoeberl, DTU Compute",   quiz: true},
      {id: "s1-moradi",    title: "Research and Chip Courses at SDU",           who: "Farshad Moradi, SDU Micro Electronics", quiz: true},
      {id: "s1-rolver",   title: "The Industry Master at DTU",                  who: "Katrine Schwab Rolver, DTU",            quiz: false}
    ] %}
    <div class="upload-slot" data-slot="{{ slot.id }}">
      <div class="slot-info">
        <strong>{{ slot.title }}</strong>
        <span style="color: var(--text-dim);"> &mdash; {{ slot.who }}</span>
      </div>
      <div class="slot-status" id="status-{{ slot.id }}">
        <span class="status-none">No file uploaded</span>
      </div>
      <form action="/2026/upload/{{ slot.id }}" method="post" enctype="multipart/form-data" class="upload-form">
        <label class="file-label">
          <input type="file" name="file" accept=".pptx,.ppt,.pdf,.key" required>
          <span class="file-btn">Choose file</span>
        </label>
        <button type="submit" class="upload-btn">Upload</button>
      </form>
      {% if slot.quiz %}
      <label class="quiz-check">
        <input type="checkbox" id="q-{{ slot.id }}" onchange="saveQuizCheck('q-{{ slot.id }}', this.checked)">
        <span>Quiz questions sent</span>
      </label>
      {% endif %}
    </div>
    {% endfor %}
  </div>

  <h2>Session 2: Technical Presentations I</h2>
